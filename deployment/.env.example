# ExamGuard Pro - Environment Variables
# Copy this file to .env and fill in your production values

# PostgreSQL
POSTGRES_USER=examguard
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=examguard

# App Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_RANDOM_SECRET

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=CHANGE_ME_JWT_SECRET

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com
